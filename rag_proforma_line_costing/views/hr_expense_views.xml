<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_expense_view_form_inherit_rag_proforma_line_costing" model="ir.ui.view">
        <field name="name">hr.expense.form.proforma.line.costing</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='total_amount_currency']" position="after">
                <field name="proforma_sale_order_id" groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>

    <record id="hr_expense_view_list_inherit_rag_proforma_line_costing" model="ir.ui.view">
        <field name="name">hr.expense.list.proforma.line.costing</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_expenses_analysis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='total_amount']" position="after">
                <field name="proforma_sale_order_id"
                       optional="hide"
                       groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>
</odoo>
