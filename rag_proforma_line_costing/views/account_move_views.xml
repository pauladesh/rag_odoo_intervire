<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_rag_proforma_line_costing" model="ir.ui.view">
        <field name="name">account.move.form.proforma.line.costing</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref'][@invisible=&quot;move_type not in ('in_invoice', 'in_receipt', 'in_refund')&quot;]" position="after">
                <field name="proforma_sale_order_id"
                       groups="account.group_account_invoice"
                       invisible="move_type not in ('in_invoice', 'in_receipt', 'in_refund')"/>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_unit']" position="after">
                <field name="incurred_cost"
                       widget="monetary"
                       optional="show"
                       groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>
</odoo>
